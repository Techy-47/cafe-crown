rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── ORDERS ────────────────────────────────────────────────────
    // Anyone can create an order (for ordering)
    // Only the customer (by phone match) can read their own order
    // Only authenticated admin can update status
    match /orders/{orderId} {
      allow create: if request.resource.data.keys().hasAll(['customerName', 'phone', 'orderType', 'items', 'total', 'status'])
                    && request.resource.data.status == 'placed'
                    && request.resource.data.items.size() >= 1
                    && request.resource.data.items.size() <= 30
                    && request.resource.data.total >= 1;

      // Public read via order ID (for tracking page)
      allow read: if true;

      // Only admin (authenticated) can update status
      allow update: if request.auth != null
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt']);

      allow delete: if false; // Never delete orders
    }

    // ── MENU ───────────────────────────────────────────────────────
    // Anyone can read the menu
    // Only admin can write
    match /menu/{itemId} {
      allow read:  if true;
      allow write: if request.auth != null;
    }

    // ── CUSTOMERS ──────────────────────────────────────────────────
    // Only admin can read customer list
    match /customers/{customerId} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null;
    }

    // ── SETTINGS ───────────────────────────────────────────────────
    match /settings/{doc} {
      allow read:  if true;
      allow write: if request.auth != null;
    }

    // ── ANALYTICS ──────────────────────────────────────────────────
    match /analytics/{doc} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null;
    }

    // Block everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
